+
+/* THE PRESS: section page immersion guard
+   Keeps category pages from flashing the old 1–2 static cards before the live archive hydrate finishes. */
+.page-section main .cards-section {
+  position: relative;
+}
+
+.page-section:not(.press-section-grid-ready) main .cards-section .cards-grid--archive {
+  max-height: 0;
+  overflow: hidden;
+  opacity: 0;
+  visibility: hidden;
+  pointer-events: none;
+  transform: translateY(10px);
+}
+
+.page-section:not(.press-section-grid-ready) main .cards-section::before {
+  content: "";
+  display: block;
+  min-height: clamp(18rem, 28vw, 27rem);
+  border: 1px solid color-mix(in srgb, var(--line) 82%, transparent);
+  border-radius: calc(var(--radius) + 2px);
+  background:
+    linear-gradient(90deg, transparent 0%, rgba(255,255,255,.38) 48%, transparent 100%),
+    radial-gradient(circle at 18% 24%, color-mix(in srgb, var(--accent-soft) 70%, transparent), transparent 24%),
+    linear-gradient(135deg, color-mix(in srgb, var(--surface) 92%, var(--accent-soft)), var(--surface-2));
+  background-size: 220% 100%, auto, auto;
+  box-shadow: var(--shadow);
+  animation: press-section-skeleton 1.35s ease-in-out infinite;
+}
+
+.page-section.press-section-grid-ready main .cards-section .cards-grid--archive {
+  animation: press-section-grid-arrive .28s ease both;
+}
+
+@keyframes press-section-skeleton {
+  0% { background-position: 120% 0, center, center; }
+  100% { background-position: -120% 0, center, center; }
+}
+
+@keyframes press-section-grid-arrive {
+  from { opacity: 0; transform: translateY(10px); }
+  to { opacity: 1; transform: translateY(0); }
+}
+
+@media (prefers-reduced-motion: reduce) {
+  .page-section:not(.press-section-grid-ready) main .cards-section::before,
+  .page-section.press-section-grid-ready main .cards-section .cards-grid--archive {
+    animation: none;
+  }
+}
