+#!/usr/bin/env python3
+"""
+Remove The Press article-body hover highlight from styles.css.
+
+Run from the repo root:
+    python3 tools/kill_article_hover_highlight.py
+
+The script is intentionally idempotent: running it more than once will not
+keep adding duplicate CSS blocks.
+"""
+from __future__ import annotations
+
+import re
+import sys
+from pathlib import Path
+
+START = "/* PRESS_NO_ARTICLE_TEXT_HOVER_HIGHLIGHT_START */"
+END = "/* PRESS_NO_ARTICLE_TEXT_HOVER_HIGHLIGHT_END */"
+
+NO_HOVER_CSS = f"""\n\n{START}\n/* No colored wash/highlight on article text hover. Keep links clickable; keep cards lifting. */\n.article-body p,\n.article-body li,\n.article-body blockquote,\n.article-body span,\n.article-body em,\n.article-body strong,\n.article-body a,\n.generated-story .article-body p,\n.generated-story .article-body li,\n.generated-story .article-body blockquote,\n.generated-story .article-body span,\n.generated-story .article-body em,\n.generated-story .article-body strong,\n.generated-story .article-body a,\n.page-article .article-body p,\n.page-article .article-body li,\n.page-article .article-body blockquote,\n.page-article .article-body span,\n.page-article .article-body em,\n.page-article .article-body strong,\n.page-article .article-body a {{\n  background: transparent !important;\n  background-color: transparent !important;\n  background-image: none !important;\n  box-shadow: none !important;\n  text-shadow: none !important;\n}}\n\n@media (hover: hover) and (pointer: fine) {{\n  body .article-body :where(p, li, blockquote, span, em, strong, a):hover,\n  body .generated-story .article-body :where(p, li, blockquote, span, em, strong, a):hover,\n  body.page-article .article-body :where(p, li, blockquote, span, em, strong, a):hover {{\n    background: transparent !important;\n    background-color: transparent !important;\n    background-image: none !important;\n    box-shadow: none !important;\n    outline: 0 !important;\n    text-shadow: none !important;\n  }}\n}}\n\n/* Also remove the colored wash that can sit behind article-card text. */\n.press-micro-card::before,\n.press-micro-card:hover::before {{\n  opacity: 0 !important;\n  background: transparent !important;\n  background-image: none !important;\n}}\n{END}\n"""
+
+# Exact rule from the dynamic-interactions block, plus whitespace-tolerant variants.
+REMOVE_PATTERNS = [
+    # Transition rule that was only there to animate the highlight.
+    re.compile(
+        r"\.article-body\s+p\s*,\s*\.generated-story\s+\.article-body\s+p\s*\{\s*"
+        r"transition\s*:\s*background-color\s+\.2s\s+ease\s*,\s*box-shadow\s+\.2s\s+ease\s*;?\s*\}\s*",
+        re.IGNORECASE,
+    ),
+    # Hover media rule that creates the pale background and left stripe.
+    re.compile(
+        r"@media\s*\(\s*hover\s*:\s*hover\s*\)\s*and\s*\(\s*pointer\s*:\s*fine\s*\)\s*\{\s*"
+        r"\.article-body\s+p:hover\s*,\s*\.generated-story\s+\.article-body\s+p:hover\s*\{[^{}]*?"
+        r"(?:background|box-shadow)[^{}]*?\}\s*\}\s*",
+        re.IGNORECASE | re.DOTALL,
+    ),
+    # A broader fallback for formatted CSS if the exact rule has been touched.
+    re.compile(
+        r"@media\s*\(\s*hover\s*:\s*hover\s*\)\s*and\s*\(\s*pointer\s*:\s*fine\s*\)\s*\{\s*"
+        r"[^{}]*?\.article-body\s+p:hover[^{}]*?\{[^{}]*?box-shadow[^{}]*?\}\s*\}\s*",
+        re.IGNORECASE | re.DOTALL,
+    ),
+]
+
+
+def find_repo_root() -> Path:
+    cwd = Path.cwd()
+    candidates = [cwd, *cwd.parents]
+    for candidate in candidates:
+        if (candidate / "styles.css").exists():
+            return candidate
+    raise FileNotFoundError("Could not find styles.css. Run this from The-Press repo root.")
+
+
+def strip_old_guard(css: str) -> str:
+    pattern = re.compile(re.escape(START) + r".*?" + re.escape(END), re.DOTALL)
+    return pattern.sub("", css).rstrip() + "\n"
+
+
+def remove_hover_rules(css: str) -> tuple[str, int]:
+    removed = 0
+    for pattern in REMOVE_PATTERNS:
+        css, count = pattern.subn("", css)
+        removed += count
+    return css, removed
+
+
+def main() -> int:
+    try:
+        root = find_repo_root()
+    except FileNotFoundError as exc:
+        print(f"ERROR: {exc}", file=sys.stderr)
+        return 1
+
+    css_path = root / "styles.css"
+    original = css_path.read_text(encoding="utf-8")
+    css = strip_old_guard(original)
+    css, removed = remove_hover_rules(css)
+    css = css.rstrip() + NO_HOVER_CSS + "\n"
+    css_path.write_text(css, encoding="utf-8")
+
+    print(f"Updated {css_path}")
+    print(f"Removed old article-hover rule blocks: {removed}")
+    print("Added hard override: article text hover backgrounds and stripes are disabled.")
+    return 0
+
+
+if __name__ == "__main__":
+    raise SystemExit(main())
